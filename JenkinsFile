pipeline {
    agent any
    tools{
        nodejs 'nodejs20'
    }
    
    environment{
        SCANNER_HOME = tool 'sonar-scanner'
        AWS_REGION = "<change-with-your-aws-region>"
        ECR_REPO_URI = "<change-with-your-aws-ecr-registry-uri>"
        IMAGE_TAG = "build-${env.BUILD_NUMBER}"
        MONGODB_URL="<change-with-your-mongodb-cloud-uri>"
        ECR_BACKEND_IMAGE_URI="<change-with-your-aws-ecr-repo-uri>"
        ECR_FRONTEND_IMAGE_URI="<change-with-your-aws-ecr-repo-uri>"
    }
    
    stages{

        stage('Git Checkout'){
            steps{
                git 'https://github.com/08abhinav/TriStack.git'
            }   
        }

        stage('Backend compilation'){
            steps{
                dir("app/backend"){
                    sh 'find . -name "*.js" -exec node --check {} +'
                }
            }
        }
        
        stage('Frontend compilation'){
            steps{
                dir("app/frontend"){
                    sh 'find . -name "*.js" -exec node --check {} +'
                }
            }
        }

        stage('GitLeaks scan'){
            steps{
                sh 'gitleaks detect --source ./app/backend --exit-code 1'
                sh 'gitleaks detect --source ./app/frontend --exit-code 1'
            }
        }
        
        stage('SonarQube Analysis'){
            steps{
                withSonarQubeEnv('sonar-server'){
                    sh """
                    $SCANNER_HOME/bin/sonar-scanner \
                    -Dsonar.projectName=Nodejs-Project \
                    -Dsonar.projectKey=Nodejs.Project \
                    -Dsonar.sources=app
                    """
                }
            }
        }
        
        stage('QualityCheck'){
            steps{
                timeout(time: 15, unit: "MINUTES"){
                    waitForQualityGate abortPipeline: false, credentialsId: 'sonar-token'
                }
            }
        }
        
        stage("Trivy FS scan"){
            steps{
                sh 'trivy fs --format table -o fs-report.html ./app/backend'
                sh 'trivy fs --format table -o fs-report.html ./app/frontend'
            }
        }
        
        stage("Login to ECR"){
            steps{
                withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', 
                accessKeyVariable: 'AWS_ACCESS_KEY_ID', 
                credentialsId: 'aws_creds', 
                secretKeyVariable: 'AWS_SECRET_ACCESS_KEY']]) 
                {
                    sh "aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${ECR_REPO_URI}"
                }
            }
        }
        
        stage("Build & Push Backend Image to ECR")
        {
            steps{
                dir("app/backend"){
                        sh """
                        # Build the image
                        docker build -t ${ECR_REPO_URI}/dev/backend:${IMAGE_TAG} .
                        
                        # Tag the image
                        docker tag ${ECR_REPO_URI}/dev/backend:${IMAGE_TAG} ${ECR_REPO_URI}/dev/backend:latest
                        
                        # Push the images
                        docker push ${ECR_REPO_URI}/dev/backend:${IMAGE_TAG}
                        docker push ${ECR_REPO_URI}/dev/backend:latest
                        """
                }
            }
        }
        
        stage("Build & Push Frontend Image to ECR")
        {
            steps{
                dir("app/frontend"){
                        sh """
                        # Build the image
                        docker build -t ${ECR_REPO_URI}/dev/frontend:${IMAGE_TAG} .
                        
                        # Tag the image
                        docker tag ${ECR_REPO_URI}/dev/frontend:${IMAGE_TAG} ${ECR_REPO_URI}/dev/frontend:latest
                        
                        # Push the images
                        docker push ${ECR_REPO_URI}/dev/frontend:${IMAGE_TAG}
                        docker push ${ECR_REPO_URI}/dev/frontend:latest
                        """
                }
            }
        }
        
        stage("Docker Deploy via compose"){
            steps{
                dir("app"){
                    sh "docker compose up -d"
                }
            }
        }
    }
}